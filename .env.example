# PhishGuard Environment Variables Template
# Copy this file to '.env' and populate it with your private keys.
# Do NOT check your actual '.env' file into public Git control!

# VirusTotal API credentials for reputational telemetry
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Google Safe Browsing API key for blacklist lookup
GOOGLE_SAFE_BROWSING_KEY=your_google_safe_browsing_key_here

# Secret key used by Flask to secure session signatures
FLASK_SECRET_KEY=change_this_to_a_long_random_string_for_production
